<Window x:Class="WPF2._0.AWTanarHozzáadás"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF2._0"
        mc:Ignorable="d"
        Title="AWTanarHozzáadás" MinHeight="200" MinWidth="200" MaxHeight="200" MaxWidth="200">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Label Content="Név:" Width="80"/>
                <TextBox x:Name="AWnameTextBox" Width="100" Margin="0,0,0,10"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Label Content="Jelszó:" Width="80"/>
                <TextBox x:Name="AWpasswordTextBox" Width="100" Margin="0,0,0,10"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Label Content="Tantárgy:" Width="80"/>
                <TextBox x:Name="AWTantargyTextBox" Width="100" Margin="0,0,0,10"/>
            </StackPanel>
            <Button x:Name="addButton" Content="Hozzáadás" Width="100" Click="AddButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
