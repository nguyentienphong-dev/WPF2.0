<Window x:Class="WPF2._0.TanarJegyBeiras"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF2._0"
        mc:Ignorable="d"
        Title="TanarJegyBeiras" MinHeight="100" MinWidth="200" MaxHeight="100" MaxWidth="200">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Label Content="Jegy:" Width="80"/>
                <TextBox x:Name="ertekTextBox" Width="100"/>
            </StackPanel>
            <Button x:Name="addButton" Content="Hozzáadás" Width="100" Click="AddButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
