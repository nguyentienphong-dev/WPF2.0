<UserControl x:Class="WPF2._0.AdminControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPF2._0"
             mc:Ignorable="d" 
             MinHeight="450" MinWidth="800" MaxHeight="450" MaxWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10">
                <GroupBox Header="Funkciók" HorizontalAlignment="Center" VerticalAlignment="Top" Width="180" Padding="10">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                        <Button x:Name="aTanuloHozzáadásButton" Content="Tanuló Hozzáadás" Width="120" Margin="0,0,0,10" Click="TanuloHozzáadásButton_Click"/>
                        <Button x:Name="aTanarHozzáadásButton" Content="Tanár Hozzáadás" Width="120" Margin="0,0,0,10" Click="TanarHozzáadásButton_Click"/>
                        <Button x:Name="aTörlésButton" Content="Felhasználó Törlése" Width="120" Margin="0,0,0,10" Click="TörlésButton_Click"/>
                        <Button x:Name="aRefreshButton" Content="Frissítés" Width="120" Margin="0,0,0,10" Click="RefreshButton_Click"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,0">
                            <CheckBox x:Name="aTanuloCheckBox" Content="Tanuló" Margin="0,0,10,0" Checked="aTanuloCheckBox_Checked" Unchecked="aTanuloCheckBox_UnChecked"/>
                            <CheckBox x:Name="aTanarCheckBox" Content="Tanár" Margin="0,0,10,0" Checked="aTanarCheckBox_Checked" Unchecked="aTanarCheckBox_UnChecked"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>

            <ContentControl Grid.Row="1" x:Name="afelhasznaloContentControl" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="10"/>
        </Grid>
        
        <Grid Grid.Column="1">
            <GroupBox Header="Felhasználók" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="10">
                <DataGrid x:Name="aUsersDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" SelectionChanged="aUsersDataGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Azonosító" Binding="{Binding Id}" Width="*" />
                        <DataGridTextColumn Header="Név" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Tantárgy" Binding="{Binding Tantargy}" Width="*"/>
                        <DataGridTextColumn Header="Osztály" Binding="{Binding Osztaly}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
